# ───────────────────────────────────────────────────────────────────────────
# Kardama.ai — environment variables
# Copy this file to `.env.local` and fill in real values for each section
# you want to enable. The app degrades gracefully if optional vars are unset.
# ───────────────────────────────────────────────────────────────────────────

# ── Supabase (REQUIRED for auth + database) ────────────────────────────────
# Auto-populated by the Vercel Marketplace Supabase integration. Pull locally:
#   vercel link
#   vercel env pull .env.local
# Without these, auth is bypassed and the app falls back to mock data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Used by the invite-cleaner email so the click-through redirects correctly.
# Local dev: http://localhost:3000  ·  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# ── Booking link tokens (REQUIRED for booking flow + campaigns) ────────────
# Used to HMAC-sign /book/<token> URLs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOOKING_TOKEN_SECRET=

# ── Twilio SMS (REQUIRED — used by AI SMS agent + outbound notifications) ─
# The AI customer agent texts customers from this number. Use a NEW Twilio
# number provisioned for the business (NOT the owner's personal cell —
# Twilio Hosted SMS is not supported on consumer wireless lines).
# Without these, the webhook 503's and outbound /api/sms/send 5xx's.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public URL Twilio is configured to POST inbound-SMS webhooks to.
# Configure in Twilio Console → Phone Numbers → your number → Messaging →
# "A MESSAGE COMES IN" → Webhook → https://kardama.ai/api/webhooks/twilio
# The webhook validates the X-Twilio-Signature header against this exact URL.
TWILIO_WEBHOOK_URL=

# ── n8n booking-cancelled webhook (OPTIONAL — sends cancellation email) ────
# When an owner deletes a scheduled job from /scheduling, the app POSTs the
# customer + job details (including a signed rebookLink) to this n8n workflow,
# which renders + sends the cancellation email. Without this URL, deletion
# still works — the email is just skipped silently.
N8N_BOOKING_CANCELLED_WEBHOOK_URL=

# ── OpenAI (REQUIRED for AI SMS agent + post generation) ──────────────────
# The AI customer agent in src/lib/ai-agent/ uses this to handle inbound SMS
# autonomously: quoting prices, checking availability, creating bookings,
# rescheduling, and escalating edge cases to the owner.
# Without this key, the webhook persists inbound SMS but no auto-reply is sent.
# Without this key the AI Post Generator also falls back to local templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google Maps Platform (REQUIRED for traffic-aware routing + address geocoding) ──
# Enable these APIs in your Google Cloud project (console.cloud.google.com):
#   - Directions API  → real-time traffic ETAs, actual road geometry per leg
#   - Geocoding API   → resolve customer address strings to lat/lng on-the-fly
# Restrict this key to "IP addresses" (your server/Vercel IPs) — never expose it client-side.
GOOGLE_MAPS_API_KEY=

# ── Google Maps JS API key (REQUIRED for Live Map + TrafficLayer) ─────────
# Browser-side Maps JavaScript API key. Restrict it to your domain in
# Google Cloud Console (HTTP referrer restrictions). The Live Map uses this
# to render Google Maps with the built-in TrafficLayer for real-time
# road-condition coloring — replaces the previous TomTom tile layer.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Admin endpoints ────────────────────────────────────────────────────────
# Bearer token required to GET /api/bookings (admin booking list).
ADMIN_API_KEY=

# ── n8n webhooks for AI agent escalation + owner notifications ────────────
# When the AI customer agent escalates a thread, the dashboard POSTs to
# N8N_AI_ESCALATION_WEBHOOK_URL with conversationId, customerPhone, reason,
# last message, and thread URL — n8n then emails + texts the owner.
# The other N8N_*_WEBHOOK_URL vars below are read by /api/intake.
N8N_AI_ESCALATION_WEBHOOK_URL=
N8N_BOOKING_WEBHOOK_URL=
N8N_CLEANER_ASSIGNMENT_WEBHOOK_URL=
N8N_UNASSIGNED_ALERT_WEBHOOK_URL=

# Owner contact for escalation alerts. The escalation workflow falls back
# to defaults if these are unset, but production should explicitly set them.
OWNER_EMAIL=
OWNER_PHONE=

# ── Web Push (REQUIRED for owner PWA notifications) ───────────────────────
# Used by /sms-inbox when the AI escalates a thread or an inbound SMS lands
# on a thread the owner has taken over. Generate keys with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: URL or https URL (e.g. mailto:owner@x.com).
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is what the browser uses to subscribe; the
# private key signs outbound pushes from the server. Without these, the
# bell button in the dashboard does nothing and pushes are skipped.
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Vercel Cron (REQUIRED for /api/campaigns/scan to run on schedule) ──────
# Vercel automatically attaches `Authorization: Bearer $CRON_SECRET` to cron
# requests. The scan endpoint refuses anything without this header so it can't
# be triggered externally. Generate with the same one-liner as the other secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Upstash Redis (RECOMMENDED — booking-store falls back to in-memory) ────
# Without these, confirmed bookings live in a Map that resets on every server
# restart. With them, bookings persist properly. Provision via the Vercel
# Marketplace: Storage → Upstash → Redis (free tier: 10K commands/day).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Vercel Edge Config (OPTIONAL — runtime feature flags / kill switches) ──
# Without this, all flags use their hardcoded defaults (everything enabled).
# Provision via Vercel dashboard: Storage → Edge Config → Create. Connect the
# resulting Edge Config to this project — Vercel auto-injects EDGE_CONFIG.
# Recognized flags (set as JSON in the Edge Config items list):
#   aiPostGenEnabled         (bool, default true)
#   cronCampaignScanEnabled  (bool, default true)
#   smsSendingEnabled        (bool, default true)
#   bookingMaintenanceBanner (string|null, default null)
EDGE_CONFIG=

# ── Deployment URL ─────────────────────────────────────────────────────────
# Used to build absolute /book/<token> URLs in outbound SMS.
# On Vercel this is auto-populated by VERCEL_URL; override here if needed.
NEXT_PUBLIC_BASE_URL=
