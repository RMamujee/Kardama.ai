# ───────────────────────────────────────────────────────────────────────────
# Kardama.ai — environment variables
# Copy this file to `.env.local` and fill in real values for each section
# you want to enable. The app degrades gracefully if optional vars are unset.
# ───────────────────────────────────────────────────────────────────────────

# ── Booking link tokens (REQUIRED for booking flow + campaigns) ────────────
# Used to HMAC-sign /book/<token> URLs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOOKING_TOKEN_SECRET=

# ── Twilio SMS (REQUIRED to actually send messages) ────────────────────────
# Without these, /api/sms/send and /api/campaigns/send return 5xx.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public URL Twilio is configured to POST inbound-SMS webhooks to
# (e.g. https://kardama.ai/api/webhooks/twilio). Required for inbox to receive.
TWILIO_WEBHOOK_URL=

# ── OpenAI (OPTIONAL — enables real AI post generation) ────────────────────
# Without this key, the AI Post Generator falls back to local templates.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Admin endpoints ────────────────────────────────────────────────────────
# Bearer token required to GET /api/bookings (admin booking list).
ADMIN_API_KEY=

# ── Vercel Cron (REQUIRED for /api/campaigns/scan to run on schedule) ──────
# Vercel automatically attaches `Authorization: Bearer $CRON_SECRET` to cron
# requests. The scan endpoint refuses anything without this header so it can't
# be triggered externally. Generate with the same one-liner as the other secrets:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Deployment URL ─────────────────────────────────────────────────────────
# Used to build absolute /book/<token> URLs in outbound SMS.
# On Vercel this is auto-populated by VERCEL_URL; override here if needed.
NEXT_PUBLIC_BASE_URL=
